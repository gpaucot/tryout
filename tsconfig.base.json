{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": false,
    "paths": {
      "@toto/design-system": ["./libs/design-system/src/index.ts"],
      "@toto/home-feature-shell": ["./libs/home/feature-shell/src/index.ts"],
      "@toto/ui-styles": ["./libs/shared/ui-styles/src/index.ts"],
      "@toto/util-types": ["./libs/shared/util-types/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
